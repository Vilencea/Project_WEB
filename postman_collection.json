        {
          "name": "Products List (flat)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/products-list/", "host": ["{{base_url}}"], "path": ["api","products-list",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"product_name\": \"Big Mac\",\n    \"price\": 1500,\n    \"Category\": 1,\n    \"isActiv\": true\n  },\n  {\n    \"id\": 2,\n    \"product_name\": \"McFlurry\",\n    \"price\": 900,\n    \"Category\": 3,\n    \"isActiv\": true\n  }\n]"
            }
          ]
        },

        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products/search/?name=mac",
              "host": ["{{base_url}}"],
              "path": ["api","products","search",""],
              "query": [{ "key": "name", "value": "mac" }]
            }
          },
          "response": [
            {
              "name": "200 OK – results found",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"product_name\": \"Big Mac\",\n    \"price\": 1500,\n    \"Category\": 1,\n    \"isActiv\": true\n  }\n]"
            },
            {
              "name": "400 No query param",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Введиите имееющий хавчик\"\n}"
            }
          ]
        }

      ]
    },

    {
      "name": "Orders",
      "description": "Checkout and order history — requires Token auth.\nNote: orders/urls.py is not yet wired in config/urls.py. Add `path('api/', include('orders.urls'))` once the file is created.",
      "item": [

        {
          "name": "Checkout (Place Order)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/checkout/", "host": ["{{base_url}}"], "path": ["api","checkout",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"product_id\": 1, \"quantity\": 2 },\n    { \"product_id\": 3, \"quantity\": 1 }\n  ],\n  \"delivery_address\": \"Almaty, Dostyk 5\",\n  \"promik\": \"STUDENT10\"\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Заказ принят\",\n  \"номер заказа\": 7\n}"
            },
            {
              "name": "400 Invalid data",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"message\": \"Заказ не оформлен\",\n  \"items\": [\"This field is required.\"]\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"detail\": \"Authentication credentials were not provided.\"\n}"
            }
          ]
        },

        {
          "name": "Order History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": { "raw": "{{base_url}}/api/orders/history/", "host": ["{{base_url}}"], "path": ["api","orders","history",""] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 5,\n    \"Создано в\": \"2025-04-18T10:23:00Z\",\n    \"Выполнен\": true\n  },\n  {\n    \"id\": 6,\n    \"Создано в\": \"2025-04-20T14:05:00Z\",\n    \"Выполнен\": false\n  }\n]"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"detail\": \"Authentication credentials were not provided.\"\n}"
            }
          ]
        }

      ]
    }

  ]
}
